{
  "productName": "OpenClaw Guardian",
  "version": "0.1.5",
  "identifier": "ai.openclaw.guardian",
  "build": {
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5201",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenClaw Guardian",
        "width": 400,
        "height": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
